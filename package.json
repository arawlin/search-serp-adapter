{
  "name": "search-serp-adapter",
  "version": "0.1.0",
  "description": "Playwright-based SERP CLI and MCP server with pluggable search engine providers.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "search-serp": "./bin/search-serp",
    "search-serp-mcp": "./bin/search-serp-mcp"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/src/index.js",
    "mcp": "tsx src/mcp-server.ts",
    "mcp:build": "npm run build && node dist/src/mcp-server.js",
    "postinstall": "playwright install chromium"
  },
  "keywords": [
    "serp",
    "search",
    "mcp",
    "playwright",
    "google",
    "baidu"
  ],
  "license": "ISC",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "commander": "^14.0.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.1.1",
    "playwright": "^1.52.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  }
}